; ##########################################
; ### Clock
; ##########################################

(defwidget bar_clock []
  (button
    :onclick "eww open calendarmenu"
    :class "bar-clock"
    (label
      :class "bar-clock"
      :text {formattime(EWW_TIME, "%d.%m.%Y | KW: %V | %H:%M:%S" )}
      )
    )
  )
